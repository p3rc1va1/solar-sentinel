# =============================================================================
# Solar Sentinel Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- Gemini API (BYOK) ---
GEMINI_API_KEY=your-gemini-api-key-here

# --- Notification: Email ---
EMAIL_ENABLED=false
EMAIL_ADDRESS=user@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=your-app-password

# --- Notification: Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=your-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# --- Detection Thresholds ---
CONFIDENCE_HIGH=0.70
CONFIDENCE_MEDIUM=0.45

# --- Capture Schedule ---
CAPTURE_INTERVAL_MINUTES=15
CAPTURE_INTERVAL_AFTER_HIGH=5
CAPTURE_INTERVAL_AFTER_CLEAN=30

# --- Model ---
YOLO_MODEL_PATH=data/models/best.pt
YOLO_INPUT_SIZE=640

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///data/solar_sentinel.db

# --- Server ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- Weather (optional, for context enrichment) ---
WEATHER_API_KEY=
WEATHER_LATITUDE=
WEATHER_LONGITUDE=
